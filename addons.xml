<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <!-- 1. YOUR REPOSITORY CONFIGURATION -->
    <addon id="repository.vkkindia" name="VKKindia Repository" version="1.0.0" provider-name="vkkindia">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="VKKindia Repository">
			<dir>
				<info compressed="false">https://vkkindia.github.io/addons.xml</info>
				<checksum>https://vkkindia.github.io/addons.xml.md5</checksum>
				<datadir zip="true">https://vkkindia.github.io/</datadir>
			</dir>
		</extension>
        <extension point="xbmc.addon.metadata">
            <summary>VKKindia Addons</summary>
            <description>Custom build repository for Hotstar and JioTV</description>
            <platform>all</platform>
        </extension>
    </addon>

    <!-- 2. JIO HOTSTAR CONFIGURATION -->
    <addon id="plugin.video.jiohotstar" name="Jio Hotstar" version="1.0.0" provider-name="GeminiCLI">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
            <import addon="script.module.inputstream.adaptive" version="19.0.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Jio Hotstar Kodi Addon</summary>
            <description lang="en_GB">Watch Jio Hotstar content on Kodi.</description>
            <platform>all</platform>
            <license>GPL-2.0-or-later</license>
        </extension>
    </addon>

    <!-- 3. JIOTV CONFIGURATION -->
    <addon id="plugin.video.jiotv" name="JioTV" version="1.0.0" provider-name="GeminiCLI">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
            <import addon="script.module.inputstream.adaptive" version="19.0.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">JioTV Kodi Addon</summary>
            <description lang="en_GB">Watch JioTV live channels on Kodi.</description>
            <platform>all</platform>
            <license>GPL-2.0-or-later</license>
        </extension>
    </addon>
</addons>
