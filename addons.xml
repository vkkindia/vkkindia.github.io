<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

    <addon id="repository.vkkindia"
           name="VKKindia Repository"
           version="1.0.0"
           provider-name="vkkindia">

        <extension point="xbmc.addon.repository">
            <dir>
                <info compressed="false">https://vkkindia.github.io/addons.xml</info>
                <checksum>https://vkkindia.github.io/addons.xml.md5</checksum>
                <datadir zip="true">https://vkkindia.github.io/</datadir>
            </dir>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>VKKindia Repository</summary>
            <description>JioTV and Hotstar addons</description>
            <platform>all</platform>
        </extension>

    </addon>

    <addon id="plugin.video.jiohotstar"
           name="Jio Hotstar"
           version="1.0.0"
           provider-name="vkkindia">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
        </requires>

        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>Jio Hotstar Kodi Addon</summary>
            <description>Watch Jio Hotstar content</description>
            <platform>all</platform>
        </extension>

    </addon>

    <addon id="plugin.video.jiotv"
           name="JioTV"
           version="1.0.0"
           provider-name="vkkindia">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
        </requires>

        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>JioTV Kodi Addon</summary>
            <description>Live TV</description>
            <platform>all</platform>
        </extension>

    </addon>

</addons>
